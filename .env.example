# ============================================================
# Environment configuration for AI HR Agent
# Copy this file to `.env` and fill in your secrets.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...your_key_here...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Application ---
APP_NAME=AI HR Screening Agent
APP_ENV=development           # development | production
DEBUG=true

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# --- Storage / DB ---
DATABASE_URL=sqlite:///./data/hr_agent.db
RESUMES_DIR=./resumes
OUTPUTS_DIR=./outputs

# --- Bias mitigation ---
ENABLE_BIAS_MASKING=true

# --- Scoring ---
SHORTLIST_THRESHOLD=65
STRONG_HIRE_THRESHOLD=80
